{
    "name": "@samatawy/rules-science",
    "version": "0.1.0",
    "description": "Science-oriented function providers for @samatawy/rules, including chemistry functions/constants, and physics constants.",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "sideEffects": false,
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "clean": "rimraf dist",
        "build": "tsup src/index.ts --format esm,cjs --dts --clean",
        "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
        "lint": "tsc --noEmit -p tsconfig.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepublishOnly": "npm run lint && npm run test && npm run build"
    },
    "keywords": [
        "rules-engine",
        "plugin",
        "science",
        "chemistry",
        "physics",
        "constants",
        "periodic-table"
    ],
    "author": "Sam Atawy <sam.atawy@gmail.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/samatawy/rules-science.git"
    },
    "bugs": {
        "url": "https://github.com/samatawy/rules-science/issues"
    },
    "homepage": "https://samatawy.github.io/rules-science/",
    "peerDependencies": {
        "@samatawy/rules": "^0.3.5"
    },
    "devDependencies": {
        "@samatawy/rules": "file:../rules",
        "@types/node": "^24.3.1",
        "rimraf": "^6.0.1",
        "tsup": "^8.5.0",
        "typescript": "^5.9.2",
        "vitest": "^3.2.4"
    }
}